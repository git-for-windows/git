#, perl-format
msgid "Failed to open %s: %s"
msgstr "%s を開けませんでした: %s"

#: git-send-email.perl
msgid "Summary email is empty, skipping it\n"
msgstr "要約メールが空のため、スキップします\n"

#. TRANSLATORS: please keep [y/N] as is.
#: git-send-email.perl
#, perl-format
msgid "Are you sure you want to use <%s> [y/N]? "
msgstr "<%s> を使用してもよろしいですか [y/N]？ "

#: git-send-email.perl
msgid ""
"The following files are 8bit, but do not declare a Content-Transfer-"
"Encoding.\n"
msgstr ""
"以下のファイルは 8bit ですが、Content-Transfer-Encoding が宣言されていませ"
"ん。\n"

#: git-send-email.perl
msgid "Which 8bit encoding should I declare [UTF-8]? "
msgstr "どの 8bit エンコーディングを宣言しますか [UTF-8]？ "

#: git-send-email.perl
#, perl-format
msgid ""
"Refusing to send because the patch\n"
"\t%s\n"
"has the template subject '*** SUBJECT HERE ***'. Pass --force if you really "
"want to send.\n"
msgstr ""
"パッチにテンプレート件名 '*** SUBJECT HERE ***' が含まれているため、送信を拒"
"否します。\n"
"\t%s\n"
"本当に送信したい場合は --force を指定してください。\n"

#: git-send-email.perl
msgid "To whom should the emails be sent (if anyone)?"
msgstr "メールは誰に送信しますか (送信する場合)？"

#: git-send-email.perl
#, perl-format
msgid "fatal: alias '%s' expands to itself\n"
msgstr "致命的: エイリアス '%s' が自身に展開されます\n"

#: git-send-email.perl
msgid "Message-ID to be used as In-Reply-To for the first email (if any)? "
msgstr "最初のメールの In-Reply-To として使用する Message-ID (ある場合)？ "

#: git-send-email.perl
#, perl-format
msgid "error: unable to extract a valid address from: %s\n"
msgstr "エラー: %s から有効なアドレスを抽出できません\n"

#. TRANSLATORS: Make sure to include [q] [d] [e] in yourtranslation. The program will only accept English inputat this point.
#: git-send-email.perl
msgid "What to do with this address? ([q]uit|[d]rop|[e]dit): "
msgstr "このアドレスをどうしますか？ ([q]uit|[d]rop|[e]dit): "

#: git-send-email.perl
#, perl-format
msgid "CA path \"%s\" does not exist"
msgstr "CA パス \"%s\" は存在しません"

#: git-send-email.perl
msgid ""
"    The Cc list above has been expanded by additional\n"
"    addresses found in the patch commit message. By default\n"
"    send-email prompts before sending whenever this occurs.\n"
"    This behavior is controlled by the sendemail.confirm\n"
"    configuration setting.\n"
"\n"
"    For additional information, run 'git send-email --help'.\n"
"    To retain the current behavior, but squelch this message,\n"
"    run 'git config --global sendemail.confirm auto'.\n"
"\n"
msgstr ""
"    上記の Cc リストは、パッチのコミットメッセージ内で見つかった\n"
"    追加のアドレスによって拡張されています。デフォルトでは、\n"
"    これが発生するたびに send-email は送信前にプロンプトを表示します。\n"
"    この動作は sendemail.confirm 設定によって制御されます。\n"
"\n"
"    詳細については、'git send-email --help' を実行してください。\n"
"    現在の動作を維持したままこのメッセージを抑制するには、\n"
"    'git config --global sendemail.confirm auto' を実行してください。\n"
"\n"

#. TRANSLATORS: Make sure to include [y] [n] [e] [q] [a] in yourtranslation. The program will only accept English inputat this point.
#: git-send-email.perl
msgid "Send this email? ([y]es|[n]o|[e]dit|[q]uit|[a]ll): "
msgstr "このメールを送信しますか？ ([y]es|[n]o|[e]dit|[q]uit|[a]ll): "

#: git-send-email.perl
msgid "Send this email reply required"
msgstr "このメールの返信送信が必要です"

#: git-send-email.perl
msgid "The destination IMAP folder is not properly defined."
msgstr "宛先 IMAP フォルダが正しく定義されていません。"

#: git-send-email.perl
msgid "The required SMTP server is not properly defined."
msgstr "必要な SMTP サーバーが正しく定義されていません。"

#: git-send-email.perl
#, perl-format
msgid "Server does not support STARTTLS! %s"
msgstr "サーバーは STARTTLS をサポートしていません！ %s"

#: git-send-email.perl
#, perl-format
msgid "STARTTLS failed! %s"
msgstr "STARTTLS に失敗しました！ %s"

#: git-send-email.perl
msgid "Unable to initialize SMTP properly. Check config and use --smtp-debug."
msgstr ""
"SMTP を正しく初期化できません。設定を確認し、--smtp-debug を使用してくださ"
"い。"

#: git-send-email.perl
#, perl-format
msgid "Outlook reassigned Message-ID to: %s\n"
msgstr "Outlook が Message-ID を再割り当てしました: %s\n"

#: git-send-email.perl
msgid "Warning: Could not retrieve Message-ID from server response.\n"
msgstr "警告: サーバー応答から Message-ID を取得できませんでした。\n"

#: git-send-email.perl
#, perl-format
msgid "Failed to send %s\n"
msgstr "%s の送信に失敗しました\n"

#: git-send-email.perl
#, perl-format
msgid "Dry-Sent %s"
msgstr "ドライ送信 %s"

#: git-send-email.perl
#, perl-format
msgid "Sent %s"
msgstr "送信済み %s"

#: git-send-email.perl
msgid "Dry-OK. Log says:"
msgstr "ドライ OK。ログ:"

#: git-send-email.perl
msgid "OK. Log says:"
msgstr "OK。ログ:"

#: git-send-email.perl
msgid "Result: "
msgstr "結果: "

#: git-send-email.perl
msgid "Result: OK"
msgstr "結果: OK"

#: git-send-email.perl
#, perl-format
msgid "can't open file %s"
msgstr "ファイル %s を開けません"

#: git-send-email.perl
#, perl-format
msgid "(mbox) Adding cc: %s from line '%s'\n"
msgstr "(mbox) cc を追加: %s (行 '%s' から)\n"

#: git-send-email.perl
#, perl-format
msgid "(mbox) Adding to: %s from line '%s'\n"
msgstr "(mbox) to を追加: %s (行 '%s' から)\n"

#: git-send-email.perl
#, perl-format
msgid "(non-mbox) Adding cc: %s from line '%s'\n"
msgstr "(non-mbox) cc を追加: %s (行 '%s' から)\n"

#: git-send-email.perl
#, perl-format
msgid "(body) Adding cc: %s from line '%s'\n"
msgstr "(body) cc を追加: %s (行 '%s' から)\n"

#: git-send-email.perl
#, perl-format
msgid "error: invalid SMTP port '%s'\n"
msgstr "エラー: 無効な SMTP ポート '%s'\n"

#: git-send-email.perl
#, perl-format
msgid "(%s) Could not execute '%s'"
msgstr "(%s) '%s' を実行できませんでした"

#: git-send-email.perl
#, perl-format
msgid "(%s) Malformed output from '%s'"
msgstr "(%s) '%s' からの出力が不正な形式です"

#: git-send-email.perl
#, perl-format
msgid "(%s) failed to close pipe to '%s'"
msgstr "(%s) '%s' へのパイプを閉じるのに失敗しました"

#: git-send-email.perl
#, perl-format
msgid "(%s) Adding %s: %s from: '%s'\n"
msgstr "(%s) %s を追加: %s 元: '%s'\n"

#: git-send-email.perl
msgid "cannot send message as 7bit"
msgstr "7bit としてメッセージを送信できません"

#: git-send-email.perl
msgid "invalid transfer encoding"
msgstr "無効な転送エンコーディング"

#: git-send-email.perl
#, perl-format
msgid ""
"fatal: %s: rejected by %s hook\n"
"%s\n"
"warning: no patches were sent\n"
msgstr ""
"致命的: %s: %s フックによって拒否されました\n"
"%s\n"
"警告: パッチは送信されませんでした\n"

#: git-send-email.perl
#, perl-format
msgid "unable to open %s: %s\n"
msgstr "%s を開けません: %s\n"

#: git-send-email.perl
#, perl-format
msgid ""
"fatal: %s:%d is longer than 998 characters\n"
"warning: no patches were sent\n"
msgstr ""
"致命的: %s:%d は 998 文字を超えています\n"
"警告: パッチは送信されませんでした\n"

#: git-send-email.perl
#, perl-format
msgid "Skipping %s with backup suffix '%s'.\n"
msgstr "%s をスキップします (バックアップ接尾辞 '%s')。\n"

#. TRANSLATORS: please keep "[y|N]" as is.
#: git-send-email.perl
#, perl-format
msgid "Do you really want to send %s? [y|N]: "
msgstr "本当に %s を送信しますか？ [y|N]: "
