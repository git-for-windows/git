msgstr ""
"--filter は extensions.partialclone で設定されたリモートでのみ使用できます"

#: builtin/fetch.c
msgid "--atomic can only be used when fetching from one remote"
msgstr "--atomic は 1 つのリモートから取得する場合にのみ使用できます"

#: builtin/fetch.c
msgid "--stdin can only be used when fetching from one remote"
msgstr "--stdin は 1 つのリモートから取得する場合にのみ使用できます"

