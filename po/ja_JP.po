msgid "allow updating of HEAD ref"
msgstr "HEAD 参照の更新を許可する"

#: builtin/fetch.c builtin/pull.c
msgid "deepen history of shallow clone"
msgstr "シャロークローンの履歴を深くする"

#: builtin/fetch.c builtin/pull.c
msgid "deepen history of shallow repository based on time"
msgstr "時間に基づいてシャローリポジトリの履歴を深くする"

#: builtin/fetch.c builtin/pull.c
msgid "convert to a complete repository"
msgstr "完全なリポジトリに変換する"

#: builtin/fetch.c
msgid "re-fetch without negotiating common commits"
msgstr "共通コミットのネゴシエーションなしで再取得する"

#: builtin/fetch.c
msgid "prepend this to submodule path output"
msgstr "サブモジュールパスの出力にこれを前置する"

#: builtin/fetch.c
msgid ""
"default for recursive fetching of submodules (lower priority than config "
"files)"
msgstr ""
"サブモジュールの再帰的取得のデフォルト (設定ファイルよりも優先度が低い)"

#: builtin/fetch.c builtin/pull.c
msgid "accept refs that update .git/shallow"
msgstr ".git/shallow を更新する参照を受け入れる"

#: builtin/fetch.c builtin/pull.c
msgid "refmap"
msgstr "refmap"

#: builtin/fetch.c builtin/pull.c
msgid "specify fetch refmap"
msgstr "fetch refmap を指定する"

#: builtin/fetch.c builtin/pull.c builtin/rebase.c builtin/replay.c
msgid "revision"
msgstr "リビジョン"

#: builtin/fetch.c builtin/pull.c
msgid "report that we have only objects reachable from this object"
msgstr ""
"このオブジェクトから到達可能なオブジェクトのみを持っていることを報告する"

#: builtin/fetch.c
msgid "do not fetch a packfile; instead, print ancestors of negotiation tips"
msgstr ""
"パックファイルを取得しない。代わりにネゴシエーションティップの祖先を表示する"

