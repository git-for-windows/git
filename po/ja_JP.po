msgid "run 'maintenance --auto' after fetching"
msgstr "取得後に 'maintenance --auto' を実行する"

#: builtin/fetch.c builtin/pull.c
msgid "check for forced-updates on all updated branches"
msgstr "更新されたすべてのブランチで強制更新をチェックする"

#: builtin/fetch.c
msgid "write the commit-graph after fetching"
msgstr "取得後に commit-graph を書き込む"

#: builtin/fetch.c
msgid "accept refspecs from stdin"
msgstr "標準入力から refspec を受け入れる"

#: builtin/fetch.c
msgid "--negotiate-only needs one or more --negotiation-tip=*"
msgstr "--negotiate-only には 1 つ以上の --negotiation-tip=* が必要です"

#: builtin/fetch.c
msgid "negative depth in --deepen is not supported"
msgstr "--deepen での負の深さはサポートされていません"

#: builtin/fetch.c
msgid "--unshallow on a complete repository does not make sense"
msgstr "完全なリポジトリに対する --unshallow は意味がありません"

#: builtin/fetch.c
#, c-format
msgid "failed to fetch bundles from '%s'"
msgstr "'%s' からのバンドルの取得に失敗しました"

#: builtin/fetch.c
msgid "fetch --all does not take a repository argument"
msgstr "fetch --all はリポジトリ引数を取りません"

#: builtin/fetch.c
msgid "fetch --all does not make sense with refspecs"
msgstr "fetch --all に refspec を指定する意味はありません"

#: builtin/fetch.c
#, c-format
msgid "no such remote or remote group: %s"
msgstr "そのようなリモートまたはリモートグループはありません: %s"

#: builtin/fetch.c
msgid "fetching a group and specifying refspecs does not make sense"
msgstr "グループの取得と refspec の指定を同時に行う意味はありません"

#: builtin/fetch.c
msgid "must supply remote when using --negotiate-only"
msgstr "--negotiate-only を使用する場合はリモートを指定する必要があります"

#: builtin/fetch.c
msgid "protocol does not support --negotiate-only, exiting"
msgstr "プロトコルは --negotiate-only をサポートしていません。終了します"

#: builtin/fetch.c
msgid ""
"--filter can only be used with the remote configured in "
